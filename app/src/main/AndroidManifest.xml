<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher_new"
        android:label="KitchenExpert"
        android:roundIcon="@mipmap/ic_launcher_new_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KitchenExpert">

        <activity
            android:name=".activities.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".activities.MainActivity" />
        <activity android:name=".activities.LoginActivity" />
        <activity android:name=".activities.AdminDashboardActivity" />
        <activity android:name=".activities.EditAdminProfileActivity" />
        <activity android:name=".activities.ManageRecipeActivity" />
        <activity android:name=".activities.ManageIngredientActivity" />
        <activity android:name=".activities.ManageRuleActivity" />
        <activity android:name=".activities.AddEditRecipeActivity" />
        <activity android:name=".activities.SelectIngredientActivity" />
        <activity android:name=".activities.RecommendationActivity" />
        <activity android:name=".activities.RecipeDetailActivity" />
        <activity android:name=".activities.HistoryActivity" />
        <activity android:name=".activities.AboutActivity" />

    </application>

</manifest>