<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:title="Admin Dashboard"
        app:titleTextColor="@color/white"
        app:titleCentered="true"
        android:elevation="4dp" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <!-- Sapaan singkat, murni tampilan, tidak mengubah fungsi -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Menu Pengelolaan"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kelola data aplikasi dari sini"
                android:textColor="#8A8A8A"
                android:textSize="13sp"
                android:layout_marginBottom="20dp" />

            <!-- Kartu tombol: Kelola Masakan -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/primary"
                android:layout_marginBottom="14dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnManageMasakan"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:text="Kelola Masakan"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:gravity="center_vertical|start"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_agenda"
                    app:iconTint="@color/white"
                    app:iconSize="26dp"
                    app:iconGravity="textStart"
                    app:iconPadding="16dp" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Kartu tombol: Kelola Bahan -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/primary"
                android:layout_marginBottom="14dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnManageBahan"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:text="Kelola Bahan"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:gravity="center_vertical|start"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_set_as"
                    app:iconTint="@color/white"
                    app:iconSize="26dp"
                    app:iconGravity="textStart"
                    app:iconPadding="16dp" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Kartu tombol: Kelola Rule -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/primary"
                android:layout_marginBottom="14dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnManageRule"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:text="Kelola Rule"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:gravity="center_vertical|start"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_sort_by_size"
                    app:iconTint="@color/white"
                    app:iconSize="26dp"
                    app:iconGravity="textStart"
                    app:iconPadding="16dp" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Kartu tombol: Edit Profil Admin -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/primary"
                android:layout_marginBottom="24dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditProfile"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:text="Edit Profil Admin"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:gravity="center_vertical|start"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_edit"
                    app:iconTint="@color/white"
                    app:iconSize="26dp"
                    app:iconGravity="textStart"
                    app:iconPadding="16dp" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Pembatas visual sebelum tombol logout -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="20dp" />

            <!-- Kartu tombol: Logout -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/orange">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogout"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:text="Logout"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:gravity="center_vertical|start"
                    app:backgroundTint="@color/orange"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_lock_power_off"
                    app:iconTint="@color/white"
                    app:iconSize="26dp"
                    app:iconGravity="textStart"
                    app:iconPadding="16dp" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>