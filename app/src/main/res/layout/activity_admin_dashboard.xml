<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:title="Admin Dashboard"
        app:titleTextColor="@color/white" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="1"
        android:padding="16dp">

        <Button
            android:id="@+id/btnManageMasakan"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginBottom="16dp"
            android:text="Kelola Masakan"
            android:backgroundTint="@color/primary"
            app:icon="@android:drawable/ic_menu_agenda"/>

        <Button
            android:id="@+id/btnManageBahan"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginBottom="16dp"
            android:text="Kelola Bahan"
            android:backgroundTint="@color/primary"
            app:icon="@android:drawable/ic_menu_set_as"/>

        <Button
            android:id="@+id/btnManageRule"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginBottom="16dp"
            android:text="Kelola Rule"
            android:backgroundTint="@color/primary"
            app:icon="@android:drawable/ic_menu_sort_by_size"/>

        <Button
            android:id="@+id/btnEditProfile"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginBottom="16dp"
            android:text="Edit Profil Admin"
            android:backgroundTint="@color/primary"
            app:icon="@android:drawable/ic_menu_edit"/>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="Logout"
            android:backgroundTint="@color/orange"
            app:icon="@android:drawable/ic_lock_power_off"/>

    </GridLayout>

</LinearLayout>